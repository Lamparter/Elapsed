{
  "iisSettings": {
    "windowsAuthentication": false,
    "anonymousAuthentication": true,
    "iisExpress": {
      "applicationUrl": "http://localhost:8080",
      "sslPort": 0
    }
  },
  "profiles": {
    // This profile is first in order for dotnet run to pick it up by default
    "Web": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "applicationUrl": "http://localhost:5000",
      "inspectUri": "{wsProtocol}://{url.hostname}:{url.port}/_framework/debug/ws-proxy?browser={browserInspectUri}",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    "Web (IIS Express)": {
      "commandName": "IISExpress",
      "launchBrowser": true,
      "inspectUri": "{wsProtocol}://{url.hostname}:{url.port}/_framework/debug/ws-proxy?browser={browserInspectUri}",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
	/*
    "Windows App SDK (Unpackaged)": {
      "commandName": "Project",
      "compatibleTargetFramework": "windows"
    },
    "Windows App SDK (Packaged)": {
      "commandName": "MsixPackage",
      "compatibleTargetFramework": "windows"
    },
	*/
    "Desktop": {
      "commandName": "Project",
      "compatibleTargetFramework": "desktop"
    },
    "Desktop (WSL2)": {
      "commandName": "WSL2",
      "commandLineArgs": "{ProjectDir}/bin/Preview/net10.0-desktop/Riverside.Elapsed.App.dll",
      "distributionName": "",
      "compatibleTargetFramework": "desktop"
    }
  }
}
