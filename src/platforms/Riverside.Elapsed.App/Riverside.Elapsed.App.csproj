<Project Sdk="Uno.Sdk">
	<PropertyGroup>
		<TargetFrameworks>net10.0-desktop;net10.0-android;net10.0-ios;net10.0-browserwasm;net10.0-windows10.0.26100.0</TargetFrameworks>

		<OutputType>Exe</OutputType>
		<UnoSingleProject>true</UnoSingleProject>

		<!--
			UnoFeatures are used to quickly add and manage features enabled for your app.
			https://aka.platform.uno/singleproject-features
		-->
		<UnoFeatures>
			Lottie;
			Hosting;
			Toolkit;
			Logging;
			LoggingSerilog;
			Mvvm;
			Configuration;
			HttpKiota;
			Serialization;
			Localization;
			Authentication;
			Navigation;
			ThemeService;
			SkiaRenderer;
		</UnoFeatures>

		<BuildTimestampIso>$([System.DateTime]::Now.ToString("O"))</BuildTimestampIso>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="SkiaSharp.Skottie" Version="3.119.0" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="$(SharedDirectory)\Riverside.Elapsed\Riverside.Elapsed.csproj" />
	</ItemGroup>

	<Target Name="GenerateBuildInfo" BeforeTargets="CoreCompile">
		<PropertyGroup>
			<GeneratedBuildInfoFile>$(IntermediateOutputPath)Generated\BuildInfo.g.cs</GeneratedBuildInfoFile>
		</PropertyGroup>

		<MakeDir Directories="$([System.IO.Path]::GetDirectoryName('$(GeneratedBuildInfoFile)'))" />

		<ItemGroup>
			<_BuildInfoLines Include="namespace Riverside.Elapsed.App.Services.Build" />
			<_BuildInfoLines Include="{" />
			<_BuildInfoLines Include="&#x9;internal static class BuildInfoGenerated" />
			<_BuildInfoLines Include="&#x9;{" />
			<_BuildInfoLines Include="&#x9;&#x9;internal const string DisplayVersion = &quot;$(DisplayVersion)&quot;%3B" />
			<_BuildInfoLines Include="&#x9;&#x9;internal const string BuildTimestampIso = &quot;$(BuildTimestampIso)&quot;%3B" />
			<_BuildInfoLines Include="&#x9;}" />
			<_BuildInfoLines Include="}" />
		</ItemGroup>

		<WriteLinesToFile
			File="$(GeneratedBuildInfoFile)"
			Overwrite="true"
			Lines="@(_BuildInfoLines)" />

		<ItemGroup>
			<Compile Include="$(GeneratedBuildInfoFile)" />
		</ItemGroup>
	</Target>

</Project>
