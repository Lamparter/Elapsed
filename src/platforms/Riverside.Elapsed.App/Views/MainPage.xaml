<Page
	x:Class="Riverside.Elapsed.App.Presentation.MainPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="using:Riverside.Elapsed.App.Presentation.Controls"
	xmlns:utu="using:Uno.Toolkit.UI"
	Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
	NavigationCacheMode="Required">
	<Grid utu:SafeArea.Insets="VisibleBounds">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<Grid Margin="24,16,24,12">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>

			<Image
				Width="56"
				Height="56"
				Source="ms-appx:///Assets/Illustrations/orpheus-cool.png" />

			<StackPanel Grid.Column="1" Margin="12,0,20,0" VerticalAlignment="Center">
				<TextBlock FontSize="30" FontWeight="SemiBold" Text="{Binding GreetingTitle}" TextWrapping="WrapWholeWords" />
				<TextBlock Margin="0,4,0,0" Opacity="0.7" Text="{Binding GreetingSubtitle}" />
			</StackPanel>

			<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
				<Button Command="{Binding OpenRecordingCommand}" Content="New timelapse session" />
				<Button Command="{Binding LogoutCommand}" Content="Sign out" />
			</StackPanel>
		</Grid>

		<ScrollViewer Grid.Row="1" HorizontalScrollMode="Disabled" VerticalScrollMode="Auto">
			<StackPanel Margin="24,0,24,8" Spacing="12">
				<Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
					<TextBox
						Width="420"
						HorizontalAlignment="Center"
						Header="Search"
						IsEnabled="{Binding IsSearchEnabled}"
						PlaceholderText="{Binding SearchPlaceholder}"
						Text="{Binding SearchText, Mode=TwoWay}" />
				</Border>

				<controls:LeaderboardControl />
				<controls:ExploreTimelapsesControl />
			</StackPanel>
		</ScrollViewer>

		<Grid Grid.Row="2" Margin="24,0,24,12">
			<Border
				Padding="10,4"
				HorizontalAlignment="Center"
				Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
				CornerRadius="99"
				Visibility="{Binding IsWebPlatform, Converter={StaticResource BoolToVisibilityConverter}}">
				<TextBlock FontSize="12" Opacity="0.75" Text="{Binding WebFooterText}" />
			</Border>

			<TextBlock
				Margin="0,8,0,0"
				HorizontalAlignment="Center"
				FontSize="12"
				Opacity="0.75"
				Text="{Binding FooterText}"
				TextWrapping="Wrap"
				Visibility="{Binding IsWebPlatform, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
		</Grid>
	</Grid>
</Page>
