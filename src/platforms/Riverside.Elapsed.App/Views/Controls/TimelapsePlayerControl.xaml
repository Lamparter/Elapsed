<UserControl
	x:Class="Riverside.Elapsed.App.Presentation.Controls.TimelapsePlayerControl"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
		<StackPanel Spacing="8">
			<TextBlock FontSize="24" FontWeight="SemiBold" Text="Timelapse player" />
			<MediaPlayerElement
				Height="420"
				AreTransportControlsEnabled="True"
				AutoPlay="False"
				Source="{Binding PlaybackUrl}" />
			<TextBlock FontSize="32" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="WrapWholeWords" />
			<TextBlock Opacity="0.7" Text="{Binding Subtitle}" TextWrapping="WrapWholeWords" />
		</StackPanel>
	</Border>
</UserControl>
