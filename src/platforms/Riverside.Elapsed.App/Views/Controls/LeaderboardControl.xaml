<UserControl
	x:Class="Riverside.Elapsed.App.Presentation.Controls.LeaderboardControl"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
		<StackPanel Spacing="12">
			<StackPanel Orientation="Horizontal" Spacing="8">
				<Image Width="32" Height="32" Source="ms-appx:///Assets/Illustrations/orpheus-woah.png" />
				<StackPanel>
					<TextBlock FontSize="24" FontWeight="SemiBold" Text="Leaderboard" />
					<TextBlock Opacity="0.7" Text="These Hack Clubbers spent the most time documenting their work!" />
				</StackPanel>
			</StackPanel>

			<ItemsRepeater ItemsSource="{Binding LeaderboardEntries}">
				<ItemsRepeater.Layout>
					<StackLayout Orientation="Horizontal" Spacing="18" />
				</ItemsRepeater.Layout>
				<ItemsRepeater.ItemTemplate>
					<DataTemplate>
						<StackPanel Width="120" Spacing="4">
							<Ellipse Width="72" Height="72">
								<Ellipse.Fill>
									<ImageBrush ImageSource="{Binding ProfilePictureUrl}" />
								</Ellipse.Fill>
							</Ellipse>
							<TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding Name}" />
							<TextBlock Opacity="0.7" Text="{Binding WeeklyText}" TextWrapping="Wrap" />
						</StackPanel>
					</DataTemplate>
				</ItemsRepeater.ItemTemplate>
			</ItemsRepeater>
		</StackPanel>
	</Border>
</UserControl>
