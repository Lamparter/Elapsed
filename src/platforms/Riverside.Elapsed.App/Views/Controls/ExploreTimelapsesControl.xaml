<UserControl
	x:Class="Riverside.Elapsed.App.Presentation.Controls.ExploreTimelapsesControl"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
		<StackPanel Spacing="12">
			<StackPanel Orientation="Horizontal" Spacing="8">
				<Image Width="32" Height="32" Source="ms-appx:///Assets/Illustrations/orpheus-cool.png" />
				<StackPanel>
					<TextBlock FontSize="24" FontWeight="SemiBold" Text="Timelapses being created now" />
					<TextBlock Opacity="0.7" Text="See what other Hack Clubbers are up to!" />
				</StackPanel>
			</StackPanel>

			<ItemsRepeater ItemsSource="{Binding ExploreTimelapses}">
				<ItemsRepeater.Layout>
					<StackLayout Orientation="Horizontal" Spacing="14" />
				</ItemsRepeater.Layout>
				<ItemsRepeater.ItemTemplate>
					<DataTemplate>
						<Border Width="300" Padding="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="6">
							<StackPanel Spacing="6">
								<Image Width="284" Height="160" Stretch="UniformToFill" Source="{Binding ThumbnailUrl}" />
								<TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="WrapWholeWords" />
								<TextBlock Opacity="0.7" Text="{Binding OwnerText}" />
								<TextBlock Opacity="0.7" Text="{Binding MetaText}" />
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsRepeater.ItemTemplate>
			</ItemsRepeater>
		</StackPanel>
	</Border>
</UserControl>
